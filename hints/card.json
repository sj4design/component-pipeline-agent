  "questions": [
    {
      "id": "content-type",
      "text": "¿Qué tipo de contenido va dentro de la card?",
      "options": [
        { "value": "text-only", "label": "Solo texto", "description": "Títulos, descripciones, metadata (ej. feature card en landing page)" },
        { "value": "image-text", "label": "Imagen + texto", "description": "Blog, producto, perfil (ej. card de catálogo e-commerce)" },
        { "value": "data", "label": "Data/Métricas", "description": "KPIs, gráficas, dashboards (ej. widget de revenue en dashboard)" },
        { "value": "any", "label": "Cualquier combinación — slot libre", "description": "Sin estructura fija; el consumidor define el contenido por instancia" }
      ],
      "impact": "Sub-componentes a incluir (.ContentMedia, .ContentBody, etc.)",
      "tags": ["media", "image", "data", "metrics", "dashboard", "product", "blog"]
    },
    {
      "id": "interaction",
      "text": "¿La card es interactiva? ¿Qué hace al interactuar?",
      "options": [
        { "value": "static", "label": "No interactiva", "description": "Solo display informativo — sin hover ni click (ej. stat card de dashboard)" },
        { "value": "navigates", "label": "Click navega a detalle", "description": "Toda la card es clickeable como link (ej. blog post card, product card)" },
        { "value": "selectable", "label": "Seleccionable", "description": "Checkbox + estado selected para selección múltiple (ej. kanban, file picker)" },
        { "value": "configurable", "label": "Configurable — varía por instancia", "description": "Algunas cards navegan, otras son estáticas; usar booleans por instancia" }
      ],
      "impact": "Is Clickable, Is Selected booleans y states hover/pressed",
      "tags": ["clickable", "selectable", "draggable", "kanban", "navigation", "link"]
    },
    {
      "id": "orientation",
      "text": "¿Qué orientaciones de layout necesita la card?",
      "options": [
        { "value": "vertical", "label": "Solo vertical — imagen arriba, contenido abajo" },
        { "value": "horizontal", "label": "Solo horizontal — imagen a la izquierda, contenido a la derecha" },
        { "value": "both", "label": "Ambas — vertical en grid, horizontal en lista" }
      ],
      "impact": "Orientation property values",
      "tags": ["vertical", "horizontal", "grid", "list", "responsive"]
    },
    {
      "id": "variants",
      "text": "¿Qué variantes visuales de card necesitas?",
      "options": [
        { "value": "elevated-only", "label": "Solo elevated — con sombra" },
        { "value": "outlined-only", "label": "Solo outlined — con borde" },
        { "value": "standard", "label": "Elevated + outlined — las más comunes" },
        { "value": "all", "label": "Todas (elevated, filled, outlined, ghost)" }
      ],
      "impact": "Variant property values",
      "tags": ["elevated", "shadow", "outlined", "border", "filled", "ghost", "flat"]
    },
    {
      "id": "anatomy",
      "text": "¿Qué elementos opcionales necesita la card?",
      "options": [
        { "value": "basic", "label": "Básico — título + descripción" },
        { "value": "media", "label": "Con media — imagen/cover arriba" },
        { "value": "actions", "label": "Con footer de acciones — botones en la parte inferior" },
        { "value": "rich", "label": "Completa — media, badge, avatar, acciones, overflow menu" }
      ],
      "impact": "Booleans Has Media, Has Actions, Has Close, etc.",
      "tags": ["media", "cover", "actions", "badge", "overflow-menu", "avatar"]
    },
    {
      "id": "structure",
      "text": "¿El contenido de la card tiene estructura predecible o es libre?",
      "options": [
        { "value": "structured", "label": "Predecible — patrón fijo (header/body/footer)" },
        { "value": "free", "label": "Libre — contenedor genérico para cualquier layout" },
        { "value": "both", "label": "Building blocks por defecto pero reemplazables" }
      ],
      "impact": "Sub-componentes como building blocks vs slots libres",
      "tags": ["building-blocks", "slots", "structured", "free-content", "flexible"]
    },
    {
      "id": "loading",
      "text": "¿La card necesita estado de carga (skeleton/loading)?",
      "options": [
        { "value": "yes", "label": "Sí — skeleton placeholder mientras carga datos" },
        { "value": "no", "label": "No — los datos siempre están disponibles" }
      ],
      "impact": "Loading boolean y skeleton sub-componente",
      "tags": ["loading", "skeleton", "placeholder", "async", "lazy"]
    },
    {
      "id": "context",
      "text": "¿En qué contexto principal se usará la card?",
      "options": [
        { "value": "catalog", "label": "Catálogo — grid de productos, artículos, usuarios" },
        { "value": "dashboard", "label": "Dashboard — métricas, KPIs, widgets" },
        { "value": "feed", "label": "Feed — social, noticias, actividad reciente" },
        { "value": "general", "label": "Uso general — múltiples contextos" }
      ],
      "impact": "Priorización de anatomía y variantes",
      "tags": ["catalog", "e-commerce", "dashboard", "feed", "social", "enterprise"]
    }
  ]
}