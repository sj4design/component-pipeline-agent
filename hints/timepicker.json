{
  "component": "TimePicker",
  "archetype": "time-input",
  "buildOrder": ["TimePicker"],
  "family": [
    {
      "name": "TimePicker",
      "isSubComponent": false,
      "slots": ["label:text", "input*:container", "clockIcon:icon", "dropdown:container", "hourColumn:container", "minuteColumn:container", "secondColumn:container", "meridiemColumn:container", "nowButton:container", "okButton:container"],
      "properties": {
        "State":     ["default", "focused", "open", "error", "disabled"],
        "Size":      ["sm", "md", "lg"],
        "Format":    ["12h", "24h"],
        "Precision": ["minute", "second"],
        "Step":      ["1", "5", "15", "30"]
      },
      "booleans": ["Has Label", "Show Clock Icon", "Show Seconds", "Show Now Button"],
      "exclusions": ["Precision=second + Step=15|30", "Format=24h + meridiemColumn"],
      "frameCount": 96
    }
  ],
  "a11y": {
    "role": "combobox + listbox (dropdown) + spinbutton segments",
    "keyboard": ["Arrow Up/Down cambia segment", "Arrow Left/Right entre segments", "Type digits", "Alt+Down abre dropdown"],
    "focus": "Ring 2px. Focus trap en dropdown."
  },
  "tokens": { "total": 22, "prefix": "tp" },
  "questions": [
    {
      "id": "use-case",
      "text": "¿Para qué usas TimePicker?",
      "options": [
        { "value": "meeting", "label": "Meeting scheduling", "description": "Inicio + fin de reunión — step=15 o 30 min, formato 12h/24h (ej. Zoom meeting scheduler)" },
        { "value": "log-entry", "label": "Log entry / registro exacto", "description": "Registrar hora precisa — step=1, incluir segundos (ej. timesheet, audit log)" },
        { "value": "booking", "label": "Booking / slots disponibles", "description": "Slots pre-definidos — step=30/60, posiblemente disabled slots no disponibles" },
        { "value": "general", "label": "Uso general — varios contextos", "description": "Meetings, logs y settings en la misma app; incluir step variable y formatos" }
      ],
      "impact": "Step default, Precision, now button",
      "tags": ["meeting", "scheduling", "alarm", "log", "booking", "settings"]
    },
    {
      "id": "format",
      "text": "¿Format?",
      "options": [
        { "value": "12h", "label": "12h — AM/PM (US convention)" },
        { "value": "24h", "label": "24h — military time (Europe)" },
        { "value": "locale", "label": "Locale-driven — auto per user region" }
      ],
      "impact": "Format property",
      "tags": ["12h", "24h", "ampm", "meridiem", "locale"]
    },
    {
      "id": "step",
      "text": "¿Step granularity?",
      "options": [
        { "value": "1-min", "label": "1 min", "description": "Log-entry / timesheet — mayor precisión" },
        { "value": "15-min", "label": "15 min", "description": "Meetings estándar — el más común en calendarios" },
        { "value": "30-min", "label": "30 min", "description": "Booking coarse — slots de cita médica, salon" },
        { "value": "variable", "label": "Variable — generar 1, 5, 15 y 30 min", "description": "Todos los steps para cubrir cualquier uso en la misma app" }
      ],
      "impact": "Step property values",
      "tags": ["step", "granularity", "1", "5", "15", "30"]
    },
    {
      "id": "seconds",
      "text": "¿Incluir seconds?",
      "options": [
        { "value": "no", "label": "No — solo hours + minutes" },
        { "value": "yes", "label": "Sí — hh:mm:ss (logs, timing precise)" }
      ],
      "impact": "Precision property, Show Seconds boolean",
      "tags": ["seconds", "precision", "hh-mm-ss"]
    },
    {
      "id": "now-button",
      "text": "¿'Ahora' shortcut?",
      "options": [
        { "value": "yes", "label": "Sí — quick 'set to current time' (booking)" },
        { "value": "no", "label": "No" }
      ],
      "impact": "Show Now Button boolean",
      "tags": ["now", "shortcut", "current-time"]
    }
  ]
}
