        { "value": "unordered", "label": "Unordered — bullets, features list" },
        { "value": "ordered", "label": "Ordered — numbered steps, ranking" },
        { "value": "description", "label": "Description (<dl>) — key/value metadata (usa DescriptionList)" },
        { "value": "nav", "label": "Nav — navigation menu items" },
        { "value": "action", "label": "Action — overflow menu con arrow keys" },
        { "value": "multiple", "label": "Varios types" }
