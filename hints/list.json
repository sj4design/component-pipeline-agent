        { "value": "none", "label": "Sin dividers" },
        { "value": "between", "label": "Entre items (padrón común)" },
        { "value": "all", "label": "All — con bordes top/bottom" }
      ],
      "impact": "Dividers property",
      "tags": ["dividers", "separators", "lines"]
