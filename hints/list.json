    },
    {
      "id": "density",
      "text": "¿Densidad?",
      "options": [
        { "value": "compact", "label": "Compact (32px) — enterprise dense" },
        { "value": "default", "label": "Default (40px) — general" },
        { "value": "comfortable", "label": "Comfortable (56px) — mobile touch" },
        { "value": "all", "label": "Las 3" }
      ],
      "impact": "Density property",
      "tags": ["compact", "default", "comfortable", "density"]
    },
    {
      "id": "item-content",
