        "Type":     ["unordered", "ordered", "description", "nav", "action"],
        "Density":  ["compact", "default", "comfortable"],
        "Dividers": ["none", "between", "all"]
      },
      "booleans": [],
      "exclusions": ["Type=nav|action + Dividers=all"],
