  "questions": [
    {
      "id": "content-type",
      "text": "¿Qué tipo de contenido muestra el tooltip?",
      "options": [
        { "value": "simple", "label": "Texto simple — una línea que describe el elemento" },
        { "value": "formatted", "label": "Texto con formato — varias líneas, negrita, código" },
        { "value": "rich", "label": "Contenido rico — imágenes, links, botones (es un Popover)" }
