      "options": [
        { "value": "icon-labels", "label": "Labels de íconos — describir icon buttons y acciones" },
        { "value": "truncated", "label": "Texto truncado — mostrar texto completo al hover" },
        { "value": "help", "label": "Ayuda contextual — explicaciones de campos o features" },
        { "value": "general", "label": "Uso general" }
      ],
      "impact": "Priorización de features y contenido",
      "tags": ["icon-label", "truncated-text", "help", "contextual", "toolbar"]
