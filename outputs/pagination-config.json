  "_decisions": [
    {
      "what": "Archetype inline-action",
      "why": "Pagination is a horizontal bar of button-like controls. 20/20 systems use flat button arrangement. Not a container, form-control, or overlay.",
      "source": "research"
    },
    {
      "what": "Family: Pagination + .PageButton sub-component",
      "why": "16/20 systems have structured page button items with own states. .PageButton has State + IsCurrent as variant dimensions. Parent Pagination only varies by Size.",
      "source": "research"
    },
    {
      "what": "IsCurrent as variant on .PageButton, not boolean",
      "why": "Current page changes bg (brand) + fg (white) = structural visual change across 2+ properties. Per global-property-rules decision tree: >= 2 properties change = variant.",
      "source": "global-property-rules"
    },
    {
      "what": "quickJumper/sizeChanger/showTotal as booleans",
      "why": "Optional UI regions that show/hide without changing structure. Per naming-conventions.md: pagination booleans are quick-jumper, size-changer, simple-mode.",
      "source": "research"
    },
    {
      "what": "6 net frames for .PageButton (10 gross - 4 exclusions)",
      "why": "State(5) x IsCurrent(2) = 10 gross. Exclude: disabled x hover/focus/pressed (3) + IsCurrent=true x disabled (1) = 4 exclusions.",
      "source": "spec"
    }
  ],
  "_foundationsRef": "foundations.json"
