  "_decisions": [
    {
      "what": "Single size (no sm/md/lg)",
      "why": "22/24 systems use a single tooltip size. Tooltip is supplementary info — no need for size hierarchy. Fixed 12px font, 6px py, 8px px matches spacing-layout.md 1.7.2 Tooltip row.",
      "source": "research"
    },
    {
      "what": "Placement as variant (top/bottom/left/right), 4 values",
      "why": "22/24 consensus on 4 basic positions. Ant's 12 positions are excessive. Auto/mostSpace = runtime behavior, not visual variant.",
      "source": "research"
    },
    {
      "what": "Arrow as boolean, not variant",
      "why": "18/24 systems use boolean toggle for arrow/caret. Does NOT multiply frames — just shows/hides arrow layer. Global-property-rules.md: binary on/off = boolean.",
      "source": "global-property-rules"
    },
    {
      "what": "hasTitle as booleanTextPair, default false",
      "why": "4/24 systems support optional title (M3 Rich, Ant). Low consensus but useful for structured context. Boolean + text pair avoids frame multiplication.",
      "source": "research"
    },
    {
      "what": "No Type variant (dark only); light mode via Figma Variables",
      "why": "20/24 systems only have dark tooltip. Light variant changes only colors, not structure — perfect use case for Figma Variable modes per global-property-rules.md section 4.",
      "source": "global-property-rules"
    }
  ],
  "_foundationsRef": "foundations.json"
