  "_decisions": [
    {
      "what": "Archetype: inline-action",
      "why": "Progress es un elemento inline que muestra estado de carga. No es contenedor ni overlay.",
      "source": "research"
    },
    {
      "what": "2 Variants: bar/circular",
      "why": "Bar es la forma lineal horizontal. Circular es el spinner determinado. 18/24 sistemas ofrecen ambas variantes.",
      "source": "research"
    },
    {
      "what": "3 Status: default/success/error",
      "why": "Default muestra progreso en curso (azul). Success indica completado (verde). Error indica fallo (rojo).",
      "source": "research+spec"
    },
    {
      "what": "18 frames netos (3x2x3)",
      "why": "3 sizes x 2 variants x 3 statuses. Sin exclusiones porque todos los combos son validos.",
      "source": "spec"
    }
  ],
