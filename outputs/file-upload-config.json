  "a11y": {
    "pattern": "file-upload",
    "role": "button (click-to-browse) + region (drop zone)",
    "ariaAttributes": [
      "Drop zone: role='button' + tabindex=0 + aria-label='Subir archivo. Arrastra o haz click para seleccionar'",
      "Hidden <input type='file'> con aria-describedby apuntando a hint text",
      "Dragover state: aria-live='polite' anuncia 'Suelta para subir'",
      "File list: role='list' + role='listitem' en cada FileItem",
      "Upload progress: aria-live='polite' con 'Subiendo archivo.pdf, 40%'",
      "Success: aria-live='polite' con 'archivo.pdf subido correctamente'",
      "Error: aria-live='assertive' con descripción específica",
      "Remove button: aria-label='Eliminar [filename]'"
    ],
    "keyboardNav": [
      "Tab al drop zone → Enter/Space abre file picker nativo",
      "Tab a cada FileItem → Enter/Space al remove button para eliminar",
      "Escape durante upload: cancela (si supported)"
    ],
    "focusTechnique": "ring 2px en drop zone y remove buttons; drop zone focuseable incluso con drag & drop disabled por keyboard users",
    "edgeCases": 8,
    "wcagLevel": "AA"
  },
  "tokens": { "total": 26, "prefix": "fu", "mode": "C" },
  "componentDescriptions": {
    "FileItem": "Item de archivo subido. State: pending / uploading (con progress bar) / success / error / paused. Sizes: sm/md.\n\n🔑 ARIA:\n• aria-live anuncia progress + final state\n• Remove button con aria-label descriptivo\n\n⌨️ Keyboard:\n• Tab al remove, Enter elimina\n\nWCAG 2.2 AA.",
    "FileUpload": "Upload de archivos con drag & drop. Variant: dropzone (area grande) / button-only (compact) / compact (inline con list). Size: sm/md/lg. State: default / hover / dragover / error / disabled.\n\n🔑 ARIA:\n• Drop zone: role='button' + tabindex (keyboard accessible incluso sin mouse)\n• aria-live anuncia progress + success + errors\n• File list: role='list'\n\n⌨️ Keyboard:\n• Tab al drop zone, Enter abre file picker\n• Drag & drop tiene fallback (click-to-browse)\n\n🎯 Focus:\n• Ring visible en drop zone\n• Remove buttons focuseables\n\nTokens: 26, prefijo fu-.\nWCAG 2.2 AA.\n\nWCAG 2.1.1 critical: drag & drop DEBE tener equivalente keyboard (file picker click). Dragover state visual + aria-live reforzado.\n\nValidation: tipo archivo (accept), size máximo, count máximo — errors específicos por tipo."
  },
  "variableBindings": {
    "fu/sm/h": "sizing/120",
    "fu/md/h": "sizing/180",
    "fu/lg/h": "sizing/240",
    "fu/default/border": "border/default",
    "fu/hover/border": "border/focus",
    "fu/dragover/bg": "brand/subtle",
    "fu/dragover/border": "interactive/default",
    "fu/error/bg": "status/error/bg",
    "fu/error/border": "status/error/border",
    "fu/disabled/bg": "surface/disabled",
    "fu/item/pending/fg": "text/secondary",
    "fu/item/uploading/bg": "brand/subtle",
    "fu/item/success/bg": "status/success/bg",
    "fu/item/error/bg": "status/error/bg",
    "fu/item/paused/bg": "status/warning/bg"
  },
  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch-fast" },
  "_decisions": [
    { "what": "3 Variants: dropzone / button-only / compact", "why": "Dropzone para primary actions (image upload, document upload); button-only para compactness (avatar upload, attach); compact para inline con file list (Gmail attach pattern).", "source": "common-patterns" },
    { "what": "5 FileItem states incluyendo paused", "why": "Large files requieren pause/resume. State=paused es estándar en enterprise file upload (Dropbox, Drive).", "source": "common-patterns" },
    { "what": "Progress bar como slot en FileItem", "why": "Visual feedback crítico durante upload. Integrado en item vs separado simplifica layout.", "source": "common-patterns" },
    { "what": "Drag & drop con keyboard fallback mandatorio", "why": "WCAG 2.1.1. Click-to-browse debe funcionar sin mouse. Drop zone es tabindex=0 + role='button'.", "source": "WCAG 2.1.1" }
  ],
  "_foundationsRef": "foundations.json"
}
