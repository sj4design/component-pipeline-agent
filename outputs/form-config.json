  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch-fast" },
  "_decisions": [
    { "what": "3 sub-components: FormField + FormSection + Form", "why": "Composición natural: Form contiene N FormSections, cada Section contiene N FormFields. Permite reutilizar FormField standalone (inline forms).", "source": "common-patterns" },
    { "what": "FormField Layout: stacked/horizontal/inline", "why": "Stacked (default mobile-first), horizontal (desktop settings con label left), inline (compact single-row forms).", "source": "common-patterns" },
    { "what": "Error message linked via aria-errormessage (WCAG)", "why": "aria-errormessage es ARIA 1.2 pattern correcto para validation. aria-describedby para helper; aria-errormessage para errors — separación semántica.", "source": "WCAG ARIA" },
    { "what": "FormSection Variants: default / card / inset", "why": "Default: spacing visual; card: elevated section (settings page pattern); inset: bg tinted section (sub-settings).", "source": "common-patterns" },
    { "what": "Focus al primer invalid field al submit", "why": "WCAG 3.3.1 Error Identification. Usuarios keyboard-only no ven visual errors en fields distantes — focus shift requerido.", "source": "WCAG 3.3.1" }
  ],
  "_foundationsRef": "foundations.json"
