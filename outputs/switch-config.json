  "_decisions": [
    {
      "what": "Archetype: form-control",
      "why": "Switch es un control binario atomico sin sub-componentes ni contenedores. 19/19 sistemas lo implementan como control simple.",
      "source": "research"
    },
    {
      "what": "isChecked como boolean de Figma, NO como variante State",
      "why": "isChecked controla track color y thumb position pero es un toggle binario. Como boolean en Figma no multiplica frames (18 vs 36). global-property-rules.md Rule 3.",
      "source": "global-property-rules"
    },
    {
      "what": "3 sizes (sm/md/lg) con track dimensions 32x16, 40x20, 48x24",
      "why": "12/19 sistemas ofrecen multiples tamanos. Track ratio 2:1 (ancho:alto) es consenso. Thumb = trackH - 4px (2px padding cada lado).",
      "source": "research"
    },
    {
      "what": "Loading como boolean overlay, no como State variant",
      "why": "Solo 3/19 sistemas tienen loading. Boolean no multiplica frames. Loading implica disabled — no necesita combinarse con otros states.",
      "source": "global-property-rules"
    },
    {
      "what": "State=disabled como variant (no boolean) — cambia fill+text, no solo opacity",
      "why": "Disabled en switch cambia track color a gris + thumb color + opacity. >= 2 propiedades visuales cambian. global-property-rules.md decision tree: >= 2 properties = VARIANT.",
      "source": "global-property-rules"
    }
  ],
  "_foundationsRef": "foundations.json"
