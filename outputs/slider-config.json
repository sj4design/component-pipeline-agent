  "componentDescriptions": {
    "Slider": "Control de rango deslizable. Types: single (1 thumb) y range (2 thumbs). Sizes: sm/md/lg.\n\n🔑 ARIA:\n• role=\"slider\" + aria-valuemin/max/now\n• aria-valuetext para valores formateados\n• Type=range: 2 thumbs independientes con aria-label\n• Has Label wired a aria-labelledby\n\n⌨️ Keyboard:\n• ←→↑↓: ±1 paso\n• Shift+Arrow: ±10 pasos\n• Page Up/Down: salto grande\n• Home/End: límites\n\n🎯 Focus:\n• Has Marks: tick marks en posiciones discretas\n• Has Input: input numérico sincronizado (Carbon pattern)\n• Has Value Label: tooltip o label con el valor actual\n• Type=range: a11y gap en AT móvil — recomienda dual inputs\n\nTokens: 10, prefijo sld-.\nWCAG 2.2 AA · ARIA slider pattern."
  },
  "variableBindings": {
    "sld/track": "border/default",
    "sld/fill": "interactive/default",
    "sld/thumb-bg": "surface/default",
    "sld/thumb-border": "interactive/default",
    "sld/mark-active": "surface/default",
    "sld/mark-inactive": "border/default",
    "sld/label-color": "text/secondary",
    "sld/value-color": "text/primary",
    "sld/disabled/fill": "border/disabled",
    "focus/ring": "border/focus"
  },
  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch" },
  "_decisions": [
    { "what": "Type=single|range como variant (no componentes separados)", "why": "Polaris usa un solo componente con valor type-switched. El overhead de mantener 2 imports no justifica la diferencia — la mayoría de productos tiene ambos casos.", "source": "research" },
    { "what": "Has Input boolean (default OFF)", "why": "Carbon hace el input paired obligatorio — muy opinado. La mayoría de casos de Zoom (volume, brightness) no necesitan input numérico. Para precision-critical (ej. configuración de threshold) se activa.", "source": "research" },
    { "what": "aria-valuetext requerido para valores formateados", "why": "Sin aria-valuetext, el SR anuncia el número crudo (50) en lugar del valor formateado ('50%' o '$50'). Ant Design lo hace per-handle. Fundamental para usabilidad con SR.", "source": "research" }
  ],
  "_foundationsRef": "foundations.json"
}
