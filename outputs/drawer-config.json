  "_decisions": [
    {
      "what": "Archetype: container",
      "why": "Drawer es un panel con regiones estructuradas (header/body/footer) como Modal y Card. 22/24 sistemas tratan drawers como contenedores con slots fijos.",
      "source": "research"
    },
    {
      "what": "Position: left/right (no top/bottom)",
      "why": "Solo 14/24 sistemas soportan 4 direcciones. Top/bottom cambian el eje del Size (ancho vs alto) y son casos raros. Left/right cubren 95%+ de los usos.",
      "source": "research"
    },
    {
      "what": "Size: sm(320)/md(480)/lg(640) con anchos fijos en px",
      "why": "Chakra define xs=256, sm=320, md=480, lg=640. Anchos fijos evitan inconsistencia. 3 sizes cubren narrow filters, standard detail, wide editor.",
      "source": "research"
    },
    {
      "what": "3 building blocks (.DrawerHeader, .DrawerBody, .DrawerFooter)",
      "why": "18/24 tienen header estructurado, 22/24 body scrollable, 14/24 footer con acciones. Building blocks permiten swap e intercambio.",
      "source": "research"
    },
    {
      "what": "6 frames netos (3 sizes x 2 positions)",
      "why": "El drawer no tiene estados interactivos propios. Booleans (header/footer/overlay/close-button/dividers) NO multiplican frames. Bien dentro del budget.",
      "source": "spec"
    }
  ],
  "_foundationsRef": "foundations.json"
