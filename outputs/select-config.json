  "_decisions": [
    {
      "what": "Archetype: composite-overlay",
      "why": "24/24 systems use trigger+dropdown pattern. Trigger is a button-like control; dropdown is an overlay panel with options.",
      "source": "research"
    },
    {
      "what": "Family: Select + .SelectOption sub-component",
      "why": "24/24 systems have structured option items. Sub-component enables option-level states (hover, selected, disabled) without multiplying parent frames.",
      "source": "research"
    },
    {
      "what": "Type as property dimension removed, using booleans instead",
      "why": "Type (single/multiple/combobox) would triple frames. Using isSearchable and hasTags booleans keeps frame count manageable. Multi-select visual differences are boolean-level (checkmarks, tags).",
      "source": "spec+global-property-rules"
    },
    {
      "what": "State includes 'open' and 'readonly'",
      "why": "Open state shows dropdown-visible trigger appearance (active border, rotated chevron). Readonly (8/24 consensus) allows focus+copy without changes, critical for enterprise.",
      "source": "research"
    },
    {
      "what": "Disabled as State variant, not boolean",
      "why": "Disabled changes fill, text color, border, AND removes interaction. Per global-property-rules decision tree: >=2 properties change = VARIANT. Exclusions prevent disabled x hover/focus/open combos.",
      "source": "global-property-rules"
    }
  ],
  "_foundationsRef": "foundations.json"
}