  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch" },
  "_decisions": [
    { "what": "allowsCustomValue como comportamiento, no variante visual", "why": "Spectrum hace la distinción más clara: false=autocomplete (revierte en blur), true=combobox (acepta cualquier valor). Esta diferencia es semántica/comportamental, no visual — no genera frames distintos.", "source": "research" },
    { "what": "State=error como frame variant (no solo color)", "why": "Error cambia el border color Y añade ícono de error Y puede mostrar texto de error debajo — requiere frame propio en Figma.", "source": "global-property-rules" },
    { "what": "Has Create como boolean (default OFF)", "why": "Polaris y Atlassian tienen patrones explícitos de 'Create [value]'. Zoom puede necesitar crear tags, etiquetas, contactos. Boolean porque es opcional, no multiplica frames.", "source": "research" }
  ],
