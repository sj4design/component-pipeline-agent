  "_decisions": [
    {
      "what": "Static label above, not floating",
      "why": "22/24 systems use static label. Simpler in Figma, no animation states. M3 floating label is outlier.",
      "source": "research"
    },
    {
      "what": "3 visual variants: outlined/filled/borderless",
      "why": "18/24 consensus. Covers standard forms, modern aesthetic, inline editing. Underlined dropped (2/24).",
      "source": "research"
    },
    {
      "what": "Status as variant (none/error/warning), not boolean",
      "why": "Status changes border color + icon + text color — ≥2 visual properties require distinct frames. Warning included per 4/24 consensus for enterprise forms.",
      "source": "global-property-rules"
    },
    {
      "what": "disabled as State variant with exclusions",
      "why": "Disabled changes border + text + bg (≥2 props) → Rule 27 decision tree → VARIANT. Exclusions: disabled × error/warning = -18 frames.",
      "source": "global-property-rules"
    },
    {
      "what": "Prefix/suffix as icon swap + text booleans",
      "why": "Technique 2: instance swap for icons (80-95% reduction). Text prefixes as booleanText pairs. No frame multiplication.",
      "source": "spec"
    }
  ],
