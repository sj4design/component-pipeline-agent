  "_decisions": [
    {
      "what": "4 placements (top/bottom/left/right), not 12 or 20",
      "why": "Tooltip in this system uses 4 positions. 12 (Ant) and 20 (Spectrum) positions are excessive for Figma variant generation. Start/end alignment is a runtime layout concern, not a visual variant. 4 directions × 3 sizes × 5 variants = 60 frames (medium complexity).",
      "source": "research + global-property-rules"
    },
    {
      "what": "Variant: default | info | warning | error | success (no 'help')",
      "why": "0/5 popover systems use semantic variants on the container — but Zoom is enterprise and inline status popovers (e.g., field validation, contextual warnings) are common. 5 variants keep it useful without over-expanding. 'help' omitted — ContextualHelp is a composable BB, not a core variant.",
      "source": "research"
    },
    {
      "what": "Arrow as boolean (Has Arrow), not a variant dimension",
      "why": "Binary on/off visual modifier. Does NOT multiply frames. Arrow direction is determined by Placement variant. Same rule as Tooltip component in this system.",
      "source": "global-property-rules"
    },
    {
      "what": "Has Title and Has Footer as booleans (booleanTextPair + booleanLayer)",
      "why": "Title and footer are optional slot regions that appear/hide without changing component structure. Binary toggle = boolean per global-property-rules. Has Title defaultVisible=true (most popovers have a title); Has Footer defaultVisible=false (footer is opt-in for action patterns).",
      "source": "global-property-rules + research"
    },
    {
      "what": "modal=false default (non-modal, no focus trap)",
      "why": "Most popover use cases (help text, contextual info, status indicators) should not trap focus. Spectrum's always-modal approach is too restrictive. Polaris's autofocusTarget=none pattern confirms non-modal as a valid accessible pattern when content is informational. Interactive popovers with forms should set modal=true.",
      "source": "research"
    },
    {
      "what": "Click as default trigger type (hover not recommended)",
      "why": "Hover-only violates WCAG 1.4.13 for keyboard users. 4/5 systems use click as primary trigger. Ant Design's hover default is a documented a11y gap. If hover is used, focus must be a co-trigger.",
      "source": "research"
    }
  ],
  "_foundationsRef": "foundations.json"
}
