  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch" },
  "_decisions": [
    { "what": "Type=count|dot|label en un solo componente", "why": "Atlassian los separa (Badge + Lozenge) pero para un sistema compacto, los 3 tipos comparten la misma forma base (pill). Un componente con Type variant es más manejable en Figma.", "source": "research" },
    { "what": "Dot siempre con color error (rojo)", "why": "M3 y 4/5 sistemas usan error color para el dot — semánticamente significa 'atención requerida'. No tiene variantes de color.", "source": "research" },
    { "what": "Conteo expuesto via parent aria-label", "why": "5/6 sistemas no dan role propio al badge. El valor se integra en la etiqueta accesible del elemento al que se superpone.", "source": "research" }
  ],
  "_foundationsRef": "foundations.json"
