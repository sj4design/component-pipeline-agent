  "_decisions": [
    {
      "what": "Archetype composite-overlay (trigger + panel)",
      "why": "21/21 systems implement menu as triggered overlay list anchored to trigger element. Universal consensus.",
      "source": "research"
    },
    {
      "what": "Family: Menu + .MenuItem + .MenuGroup",
      "why": "21/21 systems have discrete menu items with own interaction states. 14/21 have section groups with optional labels. Sub-component pattern prevents frame explosion.",
      "source": "research+spec"
    },
    {
      "what": ".MenuItem has State variant with 5 values + ItemType with 2",
      "why": "All systems differentiate hover/focus/pressed/disabled on items. 14/21 have danger/destructive item type. Using State variant because item states change bg+fg (structural, not just opacity).",
      "source": "global-property-rules"
    },
    {
      "what": "hasShortcut as booleanTextPair, not variant",
      "why": "Only 4/21 systems support keyboard shortcut display. Boolean toggle avoids frame multiplication. Enterprise apps enable it, consumer apps disable.",
      "source": "research+spec"
    },
    {
      "what": "Menu panel has Size=sm/md/lg with State=default/open",
      "why": "8/21 systems support sizing. Panel State is binary (closed=hidden, open=visible). Panel width uses min/max constraints, not fixed width.",
      "source": "research"
    }
  ],
  "_foundationsRef": "foundations.json"
