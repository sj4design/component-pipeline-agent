  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch-fast" },
  "_decisions": [
    { "what": "Segment spinbutton pattern (Spectrum)", "why": "Spectrum DatePicker/TimePicker usa segments independientes con role='spinbutton'. Elimina format parsing errors. Each segment valida independientemente.", "source": "common-patterns" },
    { "what": "Dropdown con 3-4 columns (hour/minute/AM-PM)", "why": "Alibaba/Ant/Polaris pattern. Scrollable columns vs. clock face — más denso, accesible por keyboard, funciona en narrow screens.", "source": "common-patterns" },
    { "what": "Step discrete (1/5/15/30)", "why": "Calendaring requiere 15/30 min steps (meetings); logging puede ser 1 min. 4 options cubren casos enterprise + consumer.", "source": "common-patterns" },
    { "what": "Format 12h/24h como property", "why": "US usa 12h (AM/PM); Europe usa 24h. Property explícita + detección de locale en runtime.", "source": "common-patterns" },
    { "what": "Now button shortcut", "why": "Common UX pattern: 'set to current time' reduce steps para reservation flows ('Reservar ahora').", "source": "common-patterns" }
  ],
