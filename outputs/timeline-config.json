        { "name": "title", "type": "text", "required": true, "figmaBinding": "text" },
        { "name": "description", "type": "text", "required": false, "figmaBinding": "text" },
        { "name": "actor", "type": "container", "required": false, "note": "quién hizo la acción (avatar + nombre)" },
        { "name": "content", "type": "container", "required": false, "note": "content expandido: attachments, comments, details" }
      ],
      "properties": {
