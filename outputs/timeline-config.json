        "disabled": { "markerBg": { "r": 0.88, "g": 0.88, "b": 0.90 }, "connectorColor": { "r": 0.88, "g": 0.89, "b": 0.90 }, "opacity": 0.6 }
      },
      "textProperties": [
        { "propName": "✏️ Title", "layerName": "title", "default": "Evento" },
        { "propName": "✏️ Description", "layerName": "description", "default": "Descripción del evento" },
        { "propName": "✏️ Timestamp", "layerName": "timestamp", "default": "hace 2 horas" }
      ],
      "swapSlots": [
        { "propName": "🔄 Marker", "layerName": "marker", "default": "marker/dot" }
      ],
      "booleanLayers": [
        { "propName": "👁 Has Timestamp", "layerName": "timestamp" },
        { "propName": "👁 Has Description", "layerName": "description" },
        { "propName": "👁 Has Actor", "layerName": "actor" },
        { "propName": "👁 Has Content", "layerName": "content" },
        { "propName": "👁 Show Connector", "layerName": "connectorLine" }
      ],
      "frameCount": {
