        "sm": { "markerSize": 12, "connectorThickness": 2, "fontSize": 13, "titleFontSize": 14, "descriptionFontSize": 12, "gap": 12, "verticalGap": 16 },
        "md": { "markerSize": 16, "connectorThickness": 2, "fontSize": 14, "titleFontSize": 16, "descriptionFontSize": 13, "gap": 16, "verticalGap": 24 }
      },
      "stateStyles": {
        "default": { "markerBg": { "r": 0.82, "g": 0.82, "b": 0.85 }, "markerBorder": { "r": 0.82, "g": 0.82, "b": 0.85 }, "connectorColor": { "r": 0.88, "g": 0.89, "b": 0.90 } },
        "success": { "markerBg": { "r": 0.08, "g": 0.55, "b": 0.22 }, "connectorColor": { "r": 0.08, "g": 0.55, "b": 0.22 } },
        "error":   { "markerBg": { "r": 0.86, "g": 0.15, "b": 0.15 }, "connectorColor": { "r": 0.88, "g": 0.89, "b": 0.90 } },
        "warning": { "markerBg": { "r": 0.72, "g": 0.48, "b": 0.05 }, "connectorColor": { "r": 0.88, "g": 0.89, "b": 0.90 } },
