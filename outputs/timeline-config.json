        "MarkerType":  ["dot", "icon", "avatar"],
        "Size":        ["sm", "md"],
        "IsLast":      ["no", "yes"]
      },
      "exclusions": [
        "IsLast=yes + connectorLine visible (last item no tiene trailing connector)"
      ],
