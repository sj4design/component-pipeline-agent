    "lst/py": "spacing/2"
  },
  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch-fast" },
  "_decisions": [
    { "what": "5 Types: unordered/ordered/description/nav/action", "why": "Cubre los 5 casos semantic HTML: <ul> (bullet), <ol> (numbered), <dl> (term/def), nav menu, action menu (dropdown). Type drives semantic + a11y pattern.", "source": "research" },
    { "what": "Dividers como property (none/between/all)", "why": "'between' = dividers entre items, 'all' = + top/bottom, 'none' = sin. M3 list-level divider control evita inconsistent placement.", "source": "research" },
    { "what": "3 densities (compact/default/comfortable) consistent con foundations.densityModes", "why": "Enterprise admin (32), general (40), touch mobile (56). Match con foundations.densityModes.", "source": "research" }
  ],
