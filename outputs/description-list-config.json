  "_decisions": [
    { "what": "3 Layouts: stacked / horizontal / inline", "why": "Stacked (mobile, densidad) / horizontal (settings panels side-by-side) / inline (compact metadata 'Email: foo@bar.com'). Cubre casi todos los casos.", "source": "research" },
    { "what": "Emphasis property (term / description / equal)", "why": "Settings UIs enfatizan value (description); metadata displays enfatizan label (term); comparison tables son equal. 3 values cubren los contextos.", "source": "research" },
    { "what": "Multi-column layout (1/2/3)", "why": "Product specs sheets, user details panels frecuentemente necesitan 2-3 columns para compactness. DOM order sigue linear (DL pattern), visual es grid.", "source": "research" }
  ],
