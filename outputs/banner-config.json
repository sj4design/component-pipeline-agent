  "a11y": {
    "pattern": "alert/status",
    "role": "alert (warning/error) | status (info/success)",
    "ariaAttributes": [
      "role=\"alert\" para warning y error (interrumpe SR inmediatamente)",
      "role=\"status\" para info y success (polite, no interrumpe)",
      "aria-live=\"assertive\" para page-level error/warning",
      "aria-live=\"polite\" para info/success y anuncios"
    ],
    "keyboardNav": [
      "Has Close=true: botón × es focusable y activable con Enter/Space",
      "Has Action=true: botón de acción focusable",
      "Tab: navega entre acciones dentro del banner"
    ],
    "focusTechnique": "no focus trap — inline en el flujo del documento",
    "edgeCases": 4,
    "wcagLevel": "AA"
  },
  "tokens": { "total": 18, "prefix": "bnr", "mode": "C" },
  "componentDescriptions": {
    "Banner": "Mensaje persistente de sistema. Placement: page (ancho completo, sin radius) o inline (dentro de sección, con radius y borde izquierdo). Variants: info, warning, error, success.\n\n🔑 ARIA:\n• role=\"alert\" para warning/error (interrumpe)\n• role=\"status\" para info/success (polite)\n• Has Icon: ícono es aria-hidden, color+texto transmiten el mensaje\n\n⌨️ Keyboard:\n• Has Close: botón × con aria-label='Cerrar'\n• Has Action: botón de acción con label descriptivo\n• Tab navega entre elementos interactivos\n\n🎯 Focus:\n• Sin focus trap\n• Banner page: sticky en top del viewport\n• Banner inline: flujo normal del documento\n• Error crítico: considerar no dismissible (Polaris pattern)\n\nTokens: 18, prefijo bnr-.\nWCAG 2.2 AA."
  },
  "variableBindings": {
    "bnr/info/bg": "status/info/bg", "bnr/info/border": "status/info/border", "bnr/info/icon": "status/info/fg",
    "bnr/warning/bg": "status/warning/bg", "bnr/warning/border": "status/warning/border", "bnr/warning/icon": "status/warning/fg",
    "bnr/error/bg": "status/error/bg", "bnr/error/border": "status/error/border", "bnr/error/icon": "status/error/fg",
    "bnr/success/bg": "status/success/bg", "bnr/success/border": "status/success/border", "bnr/success/icon": "status/success/fg",
    "bnr/title-color": "text/primary", "bnr/body-color": "text/secondary",
    "bnr/close-color": "text/secondary", "bnr/radius": "radius/md",
    "focus/ring": "border/focus"
  },
  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch" },
  "_decisions": [
    { "what": "Placement=page|inline (no size)", "why": "La diferencia visual clave no es tamaño sino layout — page es full-width sin radius, inline tiene radius y borde izquierdo accentuado. Polaris (el sistema más completo) también hace esta distinción.", "source": "research" },
    { "what": "role=alert para error/warning, role=status para info/success", "why": "Polaris y Atlassian hacen esta distinción. alert interrumpe el SR inmediatamente (correcto para errores urgentes); status es polite (correcto para confirmaciones).", "source": "research" },
    { "what": "Has Close=false default para error", "why": "Polaris enforces: errores críticos no son dismissibles. El usuario debe resolverlos. Warnings e info/success sí son dismissibles.", "source": "research" }
  ],
  "_foundationsRef": "foundations.json"
}
