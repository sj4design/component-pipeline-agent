    "edgeCases": [
      {
        "case": "Character count not announced to SR",
        "severity": "HIGH",
        "behavior": "Implement aria-live='polite' on counter region that announces remaining chars at thresholds (e.g., 20, 10, 5 remaining)",
        "wcag": "4.1.2"
      },
      {
        "case": "Auto-resize causes layout shift",
        "severity": "HIGH",
        "behavior": "Use bounded auto-resize (maxRows/maxHeight) to prevent content below from jumping. Smart resize (grow-only) preferred.",
        "wcag": "2.4.11"
      },
      {
        "case": "Error text replaces helper text",
        "severity": "MEDIUM",
        "behavior": "When error appears, helper text disappears. If helper contained critical instructions, include them in error message.",
        "wcag": "3.3.2"
      },
      {
        "case": "Readonly vs disabled confusion",
        "severity": "MEDIUM",
        "behavior": "Readonly: focusable, text selectable/copyable. Disabled: not focusable, not interactive. Visual distinction required.",
        "wcag": "4.1.2"
      },
      {
        "case": "Resize handle inaccessible on touch",
        "severity": "MEDIUM",
        "behavior": "CSS resize handle cannot be operated via touch. Disable resize on mobile; use auto-resize instead.",
        "wcag": "2.5.1"
      },
      {
        "case": "Max character overflow",
        "severity": "LOW",
        "behavior": "When maxLength reached via paste, truncate pasted text and announce via aria-live that content was truncated.",
        "wcag": "3.3.1"
      }
    ]
  },
