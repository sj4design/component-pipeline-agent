  "_decisions": [
    {
      "what": "Componente dedicado Textarea (no variante de TextField)",
      "why": "14/24 sistemas tienen componente separado. Multi-line tiene concerns unicos (resize, rows, character count) ausentes en single-line.",
      "source": "research"
    },
    {
      "what": "3 variantes: outlined/filled/borderless",
      "why": "Spectrum (isQuiet), Atlassian (subtle), Fluent (3 appearances) confirman necesidad de borderless para edicion inline. M3+Ant confirman outlined+filled.",
      "source": "research"
    },
    {
      "what": "disabled como State variant (no boolean)",
      "why": "Disabled cambia fill+text+border (multiple propiedades). global-property-rules.md decision tree: >=2 propiedades → variant. Exclusions evitan disabled x hover/focus.",
      "source": "global-property-rules"
    },
    {
      "what": "readonly como State variant",
      "why": "Readonly cambia border+bg (visual diferenciada). Incluido en State para tener frame dedicado. Exclusions: readonly x error/warning.",
      "source": "spec"
    },
    {
      "what": "Character count como boolean+text pair",
      "why": "14/24 sistemas soportan counter opt-in. En Figma: boolean toggle + text property para el display.",
      "source": "research"
    }
  ],
  "_foundationsRef": "foundations.json"
