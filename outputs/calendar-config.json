      "Container grid: role='grid' + aria-label='Calendario, [mes año]'",
      "Week row: role='row'",
      "Day cell: role='gridcell' + aria-label='[día del mes, mes, año, día de la semana]'",
      "Selected day: aria-selected='true'",
      "Today: aria-current='date'",
