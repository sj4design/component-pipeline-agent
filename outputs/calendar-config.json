    "cal/range-middle/bg": "brand/subtle",
    "cal/range-start/bg": "interactive/default",
    "cal/range-end/bg": "interactive/default",
    "cal/cell/fontSize/sm": "type/xs",
    "cal/cell/fontSize/md": "type/sm",
    "cal/header/fontSize/compact": "type/sm",
