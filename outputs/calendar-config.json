  },
  "_meta": { "lastUpdatedBy": "spec+enrich", "pipelineVersion": "1.0", "timestamp": "2026-04-17", "mode": "from-scratch-fast" },
  "_decisions": [
    { "what": "Calendar standalone como primitivo (Spectrum/Atlassian/Ant pattern)", "why": "M3/Carbon embeben en DatePicker; Spectrum/Atlassian/Ant tienen Calendar standalone. Zoom necesita calendar widgets en dashboards (scheduling, available slots). Standalone permite composición tanto en DatePicker como en views dedicados.", "source": "research" },
    { "what": "10 States en DayCell incluyendo range-start/end/middle", "why": "Range selection necesita visual continuity: start/end con radius parcial, middle con bg light sin radius. Modelado como States explícitos permite generar frames de todos los casos sin decorators condicionales.", "source": "research" },
    { "what": "Scale: compact / comfortable / fullscreen (Ant fullscreen pattern)", "why": "Compact 280px para sidebars; comfortable 320px para popovers; fullscreen para leave management / scheduling pages (Ant `fullscreen={true}`). Tres scales cubren todos los contextos sin propiedad size separada.", "source": "research" },
    { "what": "VisibleMonths 1 o 2 (Spectrum pattern)", "why": "Range selection con 2 meses side-by-side es el default en M3 + Spectrum. Single month suficiente para date picker popover. Property explícita controla layout.", "source": "research" },
    { "what": "Decorator slot opcional por cell (Ant dateCellRender)", "why": "Enterprise calendars muestran event count, prices, status dots en cells. Slot con instance-swap permite custom content sin hardcodear pattern específico.", "source": "research" },
    { "what": "ShowWeekNumbers como property (Ant showWeek)", "why": "Calendarios ISO para fiscal/reporting necesitan week numbers (Week 32). Columna extra a la izquierda, opt-in via property. Spectrum no lo tiene; Ant sí.", "source": "research" }
  ],
  "_foundationsRef": "foundations.json"
}
