      "selectable": "role=checkbox with aria-checked"
    },
    "keyboardNav": [
      "Tab: focus card (if interactive) or internal actions (if static)",
      "Enter: activate clickable card or focused action",
      "Space: toggle selectable card",
      "Arrow keys: navigate between cards in grid selection"
    ],
    "focusTechnique": "linear (tab between cards) or roving (arrow keys in grid)",
    "nestedInteractive": "Sibling pattern — internal links/buttons as siblings of card link, not children",
    "headingLevel": "Contextual h2-h4 via title slot. aria-labelledby pointing to title.",
    "edgeCases": 5,
