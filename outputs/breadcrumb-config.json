    "mode": "max"
  },
  "_decisions": [
    {
      "what": "Archetype inline-action, chromeless",
      "why": "Breadcrumb es lista horizontal de links sin chrome (sin bg/border/shadow). 21/21 sistemas lo implementan asi.",
      "source": "research"
    },
    {
      "what": "Family: Breadcrumb + .BreadcrumbItem sub-component",
      "why": "21/21 sistemas tienen un named child component. BreadcrumbItem tiene sus propios estados (hover/focus/pressed) e IsCurrent boolean.",
      "source": "research"
    },
    {
      "what": "IsCurrent como boolean, no State variant",
      "why": "Current page es configuracion binaria que excluye todos los estados de interaccion. global-property-rules.md: binary condition toggled by parent = boolean.",
      "source": "global-property-rules"
    },
    {
      "what": "Sin Size variant (solo md)",
      "why": "Mayoria de sistemas (17/21) solo tienen un tamano de breadcrumb. Size agrega complejidad sin beneficio para la mayoria de apps.",
      "source": "research"
    },
    {
      "what": "Separator como internal region, no slot ni prop",
      "why": "Separadores son decoracion visual aria-hidden. No son intercambiables via API — se definen en el builder. 21/21 sistemas los ocultan de AT.",
      "source": "research"
    }
  ],
  "_foundationsRef": "foundations.json"
