  "_decisions": [
    {
      "what": "Archetype: grid-tabular",
      "why": "Table es un componente tabular con celdas en grid. Patron especifico que no encaja en container ni inline-action.",
      "source": "research"
    },
    {
      "what": "4 sub-components: HeaderCell, Cell, Row, Table",
      "why": "Descomposicion canonica. HeaderCell tiene sort states. Cell tiene density. Row tiene selection states. Table es composition shell.",
      "source": "research+spec"
    },
    {
      "what": "Density en Cell (compact/default/comfortable), no Size",
      "why": "Densidad controla padding+fontSize, no el componente entero. 14/24 sistemas usan density en lugar de size para tablas.",
      "source": "research"
    },
    {
      "what": "12 frames netos total (4+3+4+1)",
      "why": "HeaderCell 4 states + Cell 3 densities + Row 4 states + Table 1 shell. Sub-components mantienen frame count bajo.",
      "source": "spec"
    }
  ],
  "_foundationsRef": "foundations.json"
}