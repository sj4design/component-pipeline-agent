  "_decisions": [
    {
      "what": "Selected como variant tri-state (unchecked/checked/indeterminate), no boolean",
      "why": "Cada valor cambia el icono visual (empty/check/dash). 24/24 sistemas reconocen tri-state. Boolean no puede representar 3 estados.",
      "source": "research"
    },
    {
      "what": "3 tamanos sm(16)/md(20)/lg(24) para la caja del control",
      "why": "Carbon usa exactamente 16/20/24. Consistencia con density system y otros form controls del DS.",
      "source": "research"
    },
    {
      "what": "isDisabled como boolean, no State variant",
      "why": "Disabled solo cambia opacity (0.5). No cambia estructura. global-property-rules decision tree: <=1 property change -> boolean.",
      "source": "global-property-rules"
    },
    {
      "what": "Status=error como variant (no boolean) porque cambia border color",
      "why": "Error cambia borde a rojo + muestra texto error. >=2 visual properties change -> variant per global-property-rules.",
      "source": "global-property-rules"
    },
    {
      "what": ".CheckboxControl como sub-componente separado",
      "why": "La caja visual se reutiliza en Checkbox y potencialmente en CheckboxCard futuro. Separar permite componer sin duplicar variants.",
      "source": "spec"
    }
  ],
  "_foundationsRef": "foundations.json"
}