  "_decisions": [
    {
      "what": "Archetype: nav-content",
      "why": "Sidebar es un panel de navegacion vertical con items, header y footer. Patron universal en aplicaciones web.",
      "source": "research"
    },
    {
      "what": "SidebarState: expanded/collapsed",
      "why": "Expanded muestra iconos + labels (260px). Collapsed muestra solo iconos (64px). 16/24 sistemas soportan ambos modos.",
      "source": "research"
    },
    {
      "what": "SidebarItem 6 states sin Size variant",
      "why": "Items tienen alto fijo 40px dentro del sidebar. No necesitan sizes independientes.",
      "source": "research+spec"
    },
    {
      "what": "2 frames netos para Sidebar",
      "why": "Expanded y collapsed. Booleans (header/footer/search) NO multiplican frames.",
      "source": "spec"
    }
  ],
