  "_decisions": [
    {
      "what": "Archetype: container",
      "why": "Accordion es un contenedor con items colapsables, cada uno con trigger + panel. Patron universal en 22/24 sistemas.",
      "source": "research"
    },
    {
      "what": "3 Variants: default/bordered/ghost",
      "why": "Default usa dividers, bordered agrega border completo, ghost elimina todos los bordes. Cubre 95%+ de casos de uso.",
      "source": "research"
    },
    {
      "what": "3 States: collapsed/expanded/disabled",
      "why": "Estados fundamentales del accordion. Expanded muestra panel, collapsed lo oculta, disabled bloquea interaccion.",
      "source": "research+spec"
    },
    {
      "what": "27 frames netos (3x3x3)",
      "why": "3 sizes x 3 variants x 3 states. Sin exclusiones porque todos los combos son validos.",
      "source": "spec"
    }
  ],
